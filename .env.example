# Never commit a real key. Revoke the key that was pasted into chat.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Resource database. Change these two values to switch Google Sheets later.
RESOURCE_SHEET_ID=1e2424AmLESZRYQKy7g3Lhcx0LtTDtYRXH2_m03lVIA0
RESOURCE_SHEET_GID=1709372674

# Deploy integrations/google-apps-script.gs as a Google Apps Script web app,
# then paste its /exec URL here.
USER_SHEET_WEBHOOK_URL=

# Deploy the same Apps Script from the Error database spreadsheet and paste its
# /exec URL here. The gid below is the current Error database sheet tab.
ERROR_SHEET_WEBHOOK_URL=
ERROR_SHEET_ID=1e2424AmLESZRYQKy7g3Lhcx0LtTDtYRXH2_m03lVIA0
ERROR_SHEET_GID=1952899933

# Reuse the same redeployed Apps Script /exec URL to update the User Count tab.
# The website stores counts internally and fills only the numeric cells hourly.
USER_COUNT_SHEET_WEBHOOK_URL=
USER_COUNT_SHEET_ID=1e2424AmLESZRYQKy7g3Lhcx0LtTDtYRXH2_m03lVIA0
USER_COUNT_SHEET_GID=1958570867
USER_COUNT_TIME_ZONE=America/Los_Angeles

# The same redeployed Apps Script URL can send password codes through Gmail.
PASSWORD_EMAIL_WEBHOOK_URL=
PASSWORD_EMAIL_FROM_ADDRESS=
